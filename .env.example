# Copy to .env.local for dev, or set as build-time env vars on your host.
# Anon key is safe to ship; row-level security in Supabase enforces ownership.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional: override the deploy base path. Default for `build:web` is `/meowDrive/`
# (matches GitHub Pages at https://<user>.github.io/meowDrive/). For root-domain
# hosts (Vercel, Cloudflare Pages with a custom domain) set this to `/`.
# MEOW_BASE=/
